{
  // ── File associations ─────────────────────────────────────────
  "files.associations": {
    "*.html": "html",
    "*.css": "css"
  },

  // ── Editor behaviour ──────────────────────────────────────────
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.formatOnSave": false,
  "editor.linkedEditing": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.stickyScroll.enabled": true,
  "editor.minimap.enabled": true,
  "editor.minimap.maxColumn": 80,
  "editor.rulers": [120],
  "editor.scrollBeyondLastLine": false,
  "editor.foldingImportsByDefault": true,
  "editor.smoothScrolling": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.renderWhitespace": "boundary",
  "editor.suggest.insertMode": "replace",

  // ── Emmet (HTML auto-complete) ────────────────────────────────
  "emmet.includeLanguages": { "html": "html" },
  "emmet.triggerExpansionOnTab": true,

  // ── Files ─────────────────────────────────────────────────────
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  // ── Live Server ───────────────────────────────────────────────
  "liveServer.settings.donotShowInfoMsg": true,
  "liveServer.settings.port": 5500,
  "liveServer.settings.CustomBrowser": "chrome",
  "liveServer.settings.NoBrowser": false,
  "liveServer.settings.ignoreFiles": [
    ".vscode/**", ".git/**", ".claude/**", "*.md", "*.txt"
  ],

  // ── Explorer: hide clutter ────────────────────────────────────
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.claude": true
  },

  // ── File nesting: only collapse config files under index.html ─
  //    craftbiz.css stays visible so you can open it directly
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "index.html": "manifest.json, sw.js, CNAME, .nojekyll, README.md, sitemap.xml, robots.txt, 404.html"
  },

  // ── Search ────────────────────────────────────────────────────
  "search.exclude": {
    "**/.git": true,
    "**/images": true
  },

  // ── Git ───────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "gitlens.hovers.currentLine.over": "line",

  // ── Spellcheck whitelist ──────────────────────────────────────
  "cSpell.words": [
    // ── Project name & tech shorthand ───────────────────────────
    "craftbiz", "ncraftbiz", "tshirt", "homedecor", "nojekyll",
    "typeOpts", "gsm", "webp", "WEBP",

    // ── CSS class name abbreviations ────────────────────────────
    "topbar", "topnav", "metabar",
    "mhdr", "xbtn", "ferr", "fsel", "ftxt", "fcheck",
    "vbtn", "ptitle", "qchip", "grev",
    "insta", "fbtn", "srch",
    "chdr", "csel", "bcol", "bbar", "blbl",
    "cust", "finp", "tabular", "nums",
    "wa-float", "pc-img",

    // ── British English (used throughout the site) ───────────────
    "colour", "colours", "Colour", "Colours", "COLOUR", "Multicolour",
    "Customise", "customise", "Customisation", "customisable",
    "customised", "Customised",
    "personalised", "Personalised",
    "Jewellery", "favourite",

    // ── Materials & printing terms ───────────────────────────────
    "Fibreboard", "Pantone", "PETG", "GSTIN",
    "yourname", "Tshirt",
    "Keychain","keychains","sublimation","Sublimation","estimator","sparkle","medallion","swatch","swatches","teak",

    // ── Payment & codes ──────────────────────────────────────────
    "NEFT", "Paytm", "BHIM", "HDFC", "ICICI", "Kotak",
    "ENDMAY", "NEWUSER", "NEWYEAR",

    // ── Festivals ────────────────────────────────────────────────
    "Holi", "HOLI", "Onam", "ONAM",

    // ── More British English ─────────────────────────────────────
    "specialise", "unauthorised", "aluminium", "Aluminium",
    "décor",

    // ── UPI / payment IDs ────────────────────────────────────────
    "craftbizbiz",

    // ── Customer names (testimonials) ────────────────────────────
    "Rajan", "Anand", "Priya", "Fathima", "Arun",

    // ── Kerala & India place names ───────────────────────────────
    "Malappuram", "Thrissur", "Kannur", "Kozhikode",
    "Karnataka", "Telangana", "Andhra", "Pradesh",
    "Nadu", "Uttar", "Madhya"
  ],

  // ── Theme (Craft Biz dark / Nothing Phone aesthetic) ──────────
  "workbench.colorCustomizations": {
    "activityBar.background": "#0f0f0f",
    "sideBar.background": "#141414",
    "sideBarSectionHeader.background": "#1a1a1a",
    "statusBar.background": "#c8401a",
    "statusBar.foreground": "#ffffff",
    "statusBarItem.hoverBackground": "#a83516",
    "editorGroupHeader.tabsBackground": "#111111",
    "tab.activeBackground": "#1a1a1a",
    "tab.inactiveBackground": "#0d0d0d",
    "tab.activeBorderTop": "#c8401a",
    "editor.lineHighlightBackground": "#1a1a1a",
    "titleBar.activeBackground": "#0f0f0f",
    "titleBar.activeForeground": "#ffffff"
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.editor.enablePreview": false
}
