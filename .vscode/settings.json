{
  "files.associations": {
    "*.html": "html",
    "*.css": "css"
  },

  "editor.formatOnSave": false,
  "editor.tabSize": 2,
  "editor.wordWrap": "on",

  "emmet.includeLanguages": {
    "html": "html"
  },

  // ── Live Server ───────────────────────────────────────────────
  "liveServer.settings.donotShowInfoMsg": true,
  "liveServer.settings.port": 5500,
  "liveServer.settings.CustomBrowser": "chrome",

  // ── Explorer: hide clutter, nest related files ────────────────
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.claude": true
  },

  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "index.html": "craftbiz.css, manifest.json, sw.js, CNAME, .nojekyll, README.md"
  },

  // ── Search / watcher ─────────────────────────────────────────
  "search.exclude": {
    "**/.git": true
  },
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/images/**": false
  },

  // ── Spellcheck whitelist ──────────────────────────────────────
  "cSpell.words": [
    "craftbiz", "tshirt", "homedecor",
    "wa-float", "pc-img", "webp", "WEBP",
    "topbar", "topnav", "mhdr", "xbtn", "ferr", "fsel",
    "ftxt", "fcheck", "vbtn", "ptitle", "qchip", "grev",
    "insta", "fbtn", "srch", "chdr", "csel", "bcol",
    "bbar", "blbl", "cust", "tabular", "nums",
    "colour", "colours", "Colour", "Colours", "COLOUR",
    "Customise", "Customisation", "favourite", "personalised",
    "Fibreboard", "Pantone", "yourname", "nojekyll",
    "NEFT", "Paytm", "BHIM", "HDFC", "ICICI", "Kotak",
    "ENDMAY", "NEWUSER",
    "Malappuram", "Thrissur", "Kannur", "Kozhikode",
    "Karnataka", "Telangana", "Andhra", "Pradesh"
  ],

  // ── Theme (Nothing Phone dark aesthetic) ─────────────────────
  "workbench.colorCustomizations": {
    "activityBar.background": "#0f0f0f",
    "sideBar.background": "#141414",
    "statusBar.background": "#c8401a",
    "statusBar.foreground": "#ffffff",
    "editorGroupHeader.tabsBackground": "#111111",
    "tab.activeBackground": "#1a1a1a",
    "tab.inactiveBackground": "#0d0d0d"
  },
  "workbench.iconTheme": "material-icon-theme"
}
